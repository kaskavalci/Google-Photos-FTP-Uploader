# Copy to .env or paste into Portainer stack env. Replace placeholders with your values.
# Do not commit .env or real credentials.

SERVER_LAN_IP=YOUR_SERVER_IP
GPHOTOS_CLI_TOKENSTORE_KEY=your-secret-passphrase
TZ=Europe/Amsterdam
NFS_PHOTOS_PATH=/mnt/nas/photos
DOCKER_DATA_PATH=/mnt/ssd/nfs/docker_data
# Optional: override processor image (default is ghcr.io/kaskavalci/google-photos-ftp-uploader:latest)
# PROCESSOR_IMAGE=ghcr.io/kaskavalci/google-photos-ftp-uploader:latest
NOTIFY_WEBHOOK_URL=http://YOUR_HA_IP:8123/api/webhook/YOUR_WEBHOOK_ID
